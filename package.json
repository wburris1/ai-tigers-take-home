{
  "name": "ai-tigers-take-home",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:all": "bash scripts/dev.sh",
    "dev:api": "cd api && python3 -m uvicorn main:app --reload --host 127.0.0.1 --port 8000",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . && npm run lint:api",
    "lint:web": "eslint .",
    "lint:api": "cd api && python3 -m ruff check .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.95.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^6.2.0"
  }
}
